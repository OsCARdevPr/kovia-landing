---
// Footer.astro
const year = new Date().getFullYear();
---

<footer class="bg-[#07080b] text-[#aeb4c2] px-6 py-12 border-t border-[#b12b24]/45" aria-label="Pie de página">
  <div class="max-w-6xl mx-auto">
    <div class="mb-8 neon-divider"></div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-10">

      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-4" aria-label="kovia">
          <span class="robotic-logo-frame">
            <img
              src="/imagenes/common/kovi.ico"
              alt="kovi mascot"
              class="w-9 h-9 object-contain"
              loading="lazy"
              decoding="async"
            />
          </span>
          <span class="font-bold text-[#ffd700] text-base">kovia</span>
        </a>
        <p class="text-sm leading-relaxed">
          Automatización con IA para empresas en El Salvador.
        </p>
      </div>

      <!-- Navigation links -->
      <nav aria-label="Navegación secundaria">
        <p class="text-white font-semibold text-sm mb-4">Navegación</p>
        <ul class="space-y-2 text-sm">
          <li><a href="#inicio" class="hover:text-[#ffd700] transition-colors">Inicio</a></li>
          <li><a href="#problemas" class="hover:text-[#ffd700] transition-colors">Problemas</a></li>
          <li><a href="#servicios" class="hover:text-[#ffd700] transition-colors">Servicios</a></li>
          <li><a href="#contacto" class="hover:text-[#ffd700] transition-colors">Contacto</a></li>
        </ul>
      </nav>

      <!-- Legal + social -->
      <div>
        <p class="text-white font-semibold text-sm mb-4">Legal</p>
        <ul class="space-y-2 text-sm mb-6">
          <li><a href="/privacidad" class="hover:text-[#ffd700] transition-colors">Privacidad</a></li>
          <li><a href="/terminos" class="hover:text-[#ffd700] transition-colors">Términos</a></li>
        </ul>
