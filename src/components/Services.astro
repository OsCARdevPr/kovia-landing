---
// Services.astro — specialized services section
const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>`,
    title: 'Automatización de flujos',
    description: 'Diseñamos procesos inteligentes que conectan tus herramientas favoritas automáticamente.',
    badge: 'N8N · Zapier · Make',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
    title: 'Chatbots Inteligentes',
    description: 'Agentes de IA conversacional que entienden el contexto y cierran ventas por ti.',
    badge: 'GPT-4 · Gemini · WhatsApp',
  },
  /*{
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>`,
    title: 'Análisis de datos',
    description: 'Transformamos datos crudos en tableros de control accionables para tu gerencia.',
    badge: 'Power BI · Looker · BigQuery',
  },*/
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"/></svg>`,
    title: 'Creacion de paginas web con Inteligencia Artificial',
    description: 'Integración perfecta entre tus sistemas de inventario, ventas y contabilidad local.',
    badge: '',
  },
];
---

<section
  id="servicios"
  class="py-24 px-6 bg-white"
  aria-labelledby="services-heading"
>
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <p class="text-sm font-semibold text-[#001e3d] uppercase tracking-widest mb-3">Soluciones</p>
      <h2 id="services-heading" class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">
        Nuestros Servicios Especializados
      </h2>
      <p class="max-w-xl mx-auto text-gray-500 text-lg">
        Tecnología de punta diseñada específicamente para las necesidades del mercado regional.
      </p>
    </div>

    <ul class="flex flex-wrap justify-center gap-6" role="list">
      {services.map((s) => (
        <li class="group relative bg-gray-50 border border-gray-100 rounded-2xl p-7 hover:border-[#001e3d]/30 hover:shadow-lg transition-all duration-200 w-full sm:w-[calc(50%-12px)] lg:w-72">
          <div class="w-14 h-14 rounded-xl bg-[#001e3d] text-white flex items-center justify-center mb-5 group-hover:scale-105 transition-transform">
            <Fragment set:html={s.icon} />
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">{s.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-4">{s.description}</p>
          <span class="inline-block text-xs font-semibold text-[#001e3d] bg-[#001e3d]/5 rounded-full px-3 py-1">
            {s.badge}
          </span>
        </li>
      ))}
    </ul>
  </div>
</section>
