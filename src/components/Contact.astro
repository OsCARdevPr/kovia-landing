---
// Contact.astro — lead generation contact section with schema
---

<section
  id="contacto"
  class="py-24 px-6 bg-gray-50"
  aria-labelledby="contact-heading"
>
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">

      <!-- Info column -->
      <div>
        <p class="text-sm font-semibold text-[#001e3d] uppercase tracking-widest mb-3">Contacto</p>
        <h2 id="contact-heading" class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-5">
          Empecemos a optimizar hoy mismo
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed mb-10">
          Completa el formulario y un especialista en IA se pondrá en contacto contigo
          en menos de 24 horas para una sesión de diagnóstico gratuita.
        </p>

        <address class="not-italic space-y-5">
          <a
            href="tel:+50322000000"
            class="flex items-center gap-4 group"
          >
            <div class="w-11 h-11 rounded-xl bg-[#001e3d]/5 flex items-center justify-center text-[#001e3d] group-hover:bg-[#001e3d]/10 transition-colors flex-shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-600 mb-0.5">Teléfono</p>
              <p class="font-semibold text-gray-800 group-hover:text-[#001e3d] transition-colors">+503 6149-2015</p>
            </div>
          </a>

          <a
            href="mailto:koviatecnologies@gmail.com"
            class="flex items-center gap-4 group"
          >
            <div class="w-11 h-11 rounded-xl bg-[#001e3d]/5 flex items-center justify-center text-[#001e3d] group-hover:bg-[#001e3d]/10 transition-colors flex-shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-600 mb-0.5">Correo</p>
              <p class="font-semibold text-gray-800 group-hover:text-[#001e3d] transition-colors">koviatecnologies@gmail.com</p>
            </div>
          </a>

          <div class="flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-[#001e3d]/5 flex items-center justify-center text-[#001e3d] flex-shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-600 mb-0.5">Ubicación</p>
              <p class="font-semibold text-gray-800">San Salvador, El Salvador</p>
            </div>
          </div>
        </address>
      </div>

      <!-- Form column -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
        <form
          name="diagnostico"
          method="POST"
          action="https://api.web3forms.com/submit"
          class="space-y-5"
          aria-label="Formulario de solicitud de diagnóstico"
          novalidate
        >
          <input type="hidden" name="access_key" value="2229503e-97e6-4447-a781-c1f02f9aa890" />
          <input type="hidden" name="subject" value="Nuevo diagnóstico solicitado — kovia" />
          <input type="hidden" name="from_name" value="kovia Landing Page" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
          <div>
            <label for="nombre" class="block text-sm font-semibold text-gray-700 mb-1.5">
              Nombre completo <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              autocomplete="name"
              placeholder="Tu nombre completo"
              required
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#001e3d] focus:border-transparent transition-shadow"
            />
          </div>

          <div>
            <label for="empresa" class="block text-sm font-semibold text-gray-700 mb-1.5">
              Empresa <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="empresa"
              name="empresa"
              autocomplete="organization"
              placeholder="Nombre de tu empresa"
              required
              class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-[#001e3d] focus:border-transparent transition-shadow"
            />
          </div>

          <div>
            <label for="whatsapp-number" class="block text-sm font-semibold text-gray-700 mb-1.5">
              WhatsApp <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <div class="flex rounded-xl border border-gray-200 focus-within:ring-2 focus-within:ring-[#001e3d] focus-within:border-transparent transition-shadow overflow-hidden">
              <!-- Country code selector -->
              <div class="relative flex-shrink-0">
                <select
                  id="phone-code"
                  class="h-full appearance-none bg-gray-50 border-r border-gray-200 pl-3 pr-7 py-3 text-sm font-medium text-gray-700 focus:outline-none cursor-pointer"
                  aria-label="Código de país"
                >
                  <option value="+503" selected>🇸🇻 +503</option>
                  <option value="+502">🇬🇹 +502</option>
                  <option value="+504">🇭🇳 +504</option>
                  <option value="+505">🇳🇮 +505</option>
                  <option value="+506">🇨🇷 +506</option>
                  <option value="+507">🇵🇦 +507</option>
                  <option value="+52">🇲🇽 +52</option>
                  <option value="+1">🇺🇸 +1</option>
                  <option value="+34">🇪🇸 +34</option>
                </select>
                <svg class="pointer-events-none absolute right-1.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/>
                </svg>
              </div>
              <!-- Number input -->
              <input
                type="tel"
                id="whatsapp-number"
                autocomplete="tel-national"
                placeholder="7802-2630"
                required
                inputmode="numeric"
                maxlength="13"
                class="flex-1 min-w-0 px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none bg-white"
              />
            </div>
            <!-- Hidden field sent to Web3Forms with full number -->
            <input type="hidden" id="whatsapp" name="whatsapp" />
          </div>

          <label class="flex items-start gap-3 cursor-pointer group">
            <div class="relative flex-shrink-0 mt-0.5">
              <input
                type="checkbox"
                name="promociones"
                id="promociones"
                value="Sí, quiero recibir promociones"
                class="peer sr-only"
              />
              <div class="w-5 h-5 rounded-md border-2 border-gray-300 bg-white peer-checked:bg-[#001e3d] peer-checked:border-[#001e3d] group-hover:border-[#001e3d]/50 transition-colors"></div>
              <svg class="absolute inset-0 w-5 h-5 p-[3px] text-white opacity-0 peer-checked:opacity-100 transition-opacity pointer-events-none" viewBox="0 0 12 10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="1.5 5.5 4.5 8.5 10.5 1.5"/>
              </svg>
            </div>
            <span class="text-sm text-gray-600 leading-snug group-hover:text-gray-800 transition-colors">
              Quiero estar al tanto de promociones, novedades y consejos de automatización de <strong class="text-[#001e3d] font-semibold">kovia</strong>.
            </span>
          </label>

          <button
            type="submit"
            class="w-full bg-[#001e3d] text-white font-bold py-3.5 rounded-xl hover:bg-[#00294f] transition-colors focus:outline-none focus:ring-2 focus:ring-[#001e3d] focus:ring-offset-2"
          >
            Solicitar Diagnóstico Gratuito
          </button>
<!--           
          <p class="text-xs text-gray-600 text-center">
            Al enviar, aceptas nuestra
            <a href="/privacidad" class="underline hover:text-[#001e3d]">Política de Privacidad</a>
            y
            <a href="/terminos" class="underline hover:text-[#001e3d]">Términos de Servicio</a>.
          </p> -->
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const codeSelect = document.getElementById('phone-code') as HTMLSelectElement;
  const numberInput = document.getElementById('whatsapp-number') as HTMLInputElement;
  const hiddenField = document.getElementById('whatsapp') as HTMLInputElement;
  const form = numberInput?.closest('form');

  // Format rules per country code
  const formats: Record<string, { maxDigits: number; pattern: (d: string) => string }> = {
    '+503': { maxDigits: 8, pattern: d => d.length <= 4 ? d : `${d.slice(0,4)}-${d.slice(4,8)}` },
    '+502': { maxDigits: 8, pattern: d => d.length <= 4 ? d : `${d.slice(0,4)}-${d.slice(4,8)}` },
    '+504': { maxDigits: 8, pattern: d => d.length <= 4 ? d : `${d.slice(0,4)}-${d.slice(4,8)}` },
    '+505': { maxDigits: 8, pattern: d => d.length <= 4 ? d : `${d.slice(0,4)}-${d.slice(4,8)}` },
    '+506': { maxDigits: 8, pattern: d => d.length <= 4 ? d : `${d.slice(0,4)}-${d.slice(4,8)}` },
    '+507': { maxDigits: 8, pattern: d => d.length <= 4 ? d : `${d.slice(0,4)}-${d.slice(4,8)}` },
    '+52':  { maxDigits: 10, pattern: d => d.length <= 3 ? d : d.length <= 6 ? `${d.slice(0,3)}-${d.slice(3)}` : `${d.slice(0,3)}-${d.slice(3,6)}-${d.slice(6,10)}` },
    '+1':   { maxDigits: 10, pattern: d => d.length <= 3 ? d : d.length <= 6 ? `(${d.slice(0,3)}) ${d.slice(3)}` : `(${d.slice(0,3)}) ${d.slice(3,6)}-${d.slice(6,10)}` },
    '+34':  { maxDigits: 9,  pattern: d => d.length <= 3 ? d : d.length <= 6 ? `${d.slice(0,3)} ${d.slice(3)}` : `${d.slice(0,3)} ${d.slice(3,6)} ${d.slice(6,9)}` },
  };

  function getFormat() {
    return formats[codeSelect?.value] ?? formats['+503'];
  }

  function formatNumber(raw: string) {
    const digits = raw.replace(/\D/g, '');
    const { maxDigits, pattern } = getFormat();
    const capped = digits.slice(0, maxDigits);
    return pattern(capped);
  }

  function syncHidden() {
    if (hiddenField) {
      const digits = numberInput.value.replace(/\D/g, '');
      hiddenField.value = digits ? `${codeSelect.value} ${numberInput.value}` : '';
    }
  }

  numberInput?.addEventListener('input', (e) => {
    const input = e.target as HTMLInputElement;
    const cursorPos = input.selectionStart ?? 0;
    const prevLen = input.value.length;

    const formatted = formatNumber(input.value);
    input.value = formatted;

    // Adjust cursor position after formatting
    const diff = formatted.length - prevLen;
    input.setSelectionRange(cursorPos + diff, cursorPos + diff);

    syncHidden();
  });

  codeSelect?.addEventListener('change', () => {
    // Reformat with new country rules
    numberInput.value = formatNumber(numberInput.value);
    syncHidden();
  });

  // On submit, validate digit count and sync hidden field
  form?.addEventListener('submit', (e) => {
    const digits = numberInput.value.replace(/\D/g, '');
    const { maxDigits } = getFormat();
    if (digits.length < maxDigits) {
      e.preventDefault();
      numberInput.setCustomValidity(`Ingresa los ${maxDigits} dígitos del número`);
      numberInput.reportValidity();
      return;
    }
    numberInput.setCustomValidity('');
    syncHidden();
  });

  numberInput?.addEventListener('input', () => numberInput.setCustomValidity(''));
</script>
