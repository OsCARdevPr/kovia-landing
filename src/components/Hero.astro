---
// Hero.astro — full-height hero with spotlight, floating icons & social proof cards

interface TestimonialCard {
  type: 'testimonial';
  cls: string; side: string; width: string;
  initials: string; color: string;
  name: string; role: string;
  text: string; stars: boolean;
}
interface MetricCard {
  type: 'metric';
  cls: string; side: string; width: string;
  label: string; value: string; sub: string;
}
type FloatingCard = TestimonialCard | MetricCard;

const floatingIcons = [
  { cls: 'fi-1', left: '4%',  src: '/imagenes/heroSection/flaotin-icons/antropic-ia-floating.webp', size: 'w-70 h-12' },
  { cls: 'fi-2', left: '16%', src: '/imagenes/heroSection/flaotin-icons/gemini-ia-gemini.webp',             size: 'w-25 h-14' },
  { cls: 'fi-3', left: '28%', src: '/imagenes/heroSection/flaotin-icons/open-ia-floating.webp', size: 'w-24 h-15'   },
  { cls: 'fi-4', left: '44%', src: '/imagenes/heroSection/flaotin-icons/gemini-ia-gemini.webp',             size: 'w-25 h-14' },
  { cls: 'fi-5', left: '60%', src: '/imagenes/heroSection/flaotin-icons/antropic-ia-floating.webp', size: 'w-70 h-10' },
  { cls: 'fi-6', left: '74%', src: '/imagenes/heroSection/flaotin-icons/gemini-ia-gemini.webp',             size: 'w-25 h-14' },
  { cls: 'fi-7', left: '88%', src: '/imagenes/heroSection/flaotin-icons/open-ia-floating.webp', size: 'w-24 h-15'   },
];

const floatingCards: FloatingCard[] = [
  {
    type: 'testimonial',
    cls: 'fc-1', side: 'left:3%',   width: 'w-56',
    initials: 'MA', color: 'bg-blue-700',
    name: 'María Alvarado', role: 'Gerente de Ops',
    text: '"Redujimos tareas manuales en un 70%. kovia entendió nuestro negocio desde el día uno."',
    stars: true,
  },
  {
    type: 'testimonial',
    cls: 'fc-2', side: 'left:20%',  width: 'w-52',
    initials: 'CR', color: 'bg-emerald-700',
    name: 'Carlos Rivera', role: 'Director Comercial',
    text: '"Implementamos el chatbot en 10 días. Las consultas se atienden solas."',
    stars: false,
  },
  {
    type: 'testimonial',
    cls: 'fc-3', side: 'right:18%', width: 'w-56',
    initials: 'LP', color: 'bg-purple-700',
    name: 'Laura Portillo', role: 'CEO · Distribuidora',
    text: '"El análisis de datos nos mostró oportunidades que no veíamos. Increíble ROI."',
    stars: true,
  },
  {
    type: 'metric',
    cls: 'fc-4', side: 'right:3%',  width: 'w-48',
    label: 'Ahorro promedio', value: '68%', sub: 'en tareas operativas',
  },
];
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center px-6 overflow-hidden bg-gradient-to-br from-[#001e3d] via-[#00294f] to-[#003366]"
  aria-labelledby="hero-heading"
>
  <!-- Grid pattern -->
  <div class="absolute inset-0 opacity-[0.04]" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <!-- Bottom spotlight glow -->
  <div class="absolute bottom-0 inset-x-0 pointer-events-none" aria-hidden="true">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[900px] h-[380px] bg-blue-500/20 blur-[110px] rounded-full"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[420px] h-[220px] bg-cyan-400/25 blur-[70px] rounded-full"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[180px] h-[120px] bg-white/10 blur-[40px] rounded-full"></div>
  </div>

  <!-- Floating icons (real images) -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    {floatingIcons.map(icon => (
      <div class={`float-icon ${icon.cls} absolute bottom-0`} style={`left:${icon.left}`}>
        <img src={icon.src} alt="" class={`${icon.size} rounded-2xl shadow-lg`} />
      </div>
    ))}
  </div>

  <!-- Floating comment cards — rise from bottom, fade at midpoint -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden hidden lg:block" aria-hidden="true">
    {floatingCards.map(card => (
      <div class={`float-card ${card.cls} absolute bottom-0`} style={card.side}>
        {card.type === 'metric' ? (
          <div class={`${card.width} rounded-2xl bg-white/10 border border-white/20 backdrop-blur-xl p-4 shadow-xl`}>
            <p class="text-blue-200/60 text-[10px] uppercase tracking-wider mb-1">{card.label}</p>
            <p class="text-white text-2xl font-extrabold">{card.value}</p>
            <p class="text-blue-100/60 text-xs">{card.sub}</p>
          </div>
        ) : (
          <div class={`${card.width} rounded-2xl bg-white/10 border border-white/20 backdrop-blur-xl p-4 shadow-xl`}>
            <div class="flex items-center gap-3 mb-2">
              <div class={`w-8 h-8 rounded-full ${card.color} flex items-center justify-center text-white text-xs font-bold flex-shrink-0`}>{card.initials}</div>
              <div>
                <p class="text-white text-xs font-semibold">{card.name}</p>
                <p class="text-blue-200/60 text-[10px]">{card.role}</p>
              </div>
            </div>
            <p class="text-blue-100/80 text-xs leading-relaxed">{card.text}</p>
            {card.stars && <p class="mt-2 text-yellow-400 text-xs tracking-widest">★★★★★</p>}
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- Main content -->
  <div class="relative z-10 max-w-2xl mx-auto text-center py-8">
    <!-- Badge -->
    <p class="inline-flex items-center gap-2 text-sm font-medium text-blue-200 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 mb-8">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      Innovación en El Salvador
    </p>

    <!-- H1 -->
    <h1
      id="hero-heading"
      class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6"
    >
      Automatiza el futuro de<br class="hidden sm:block" />
      <span class="text-blue-300">tu empresa en El Salvador con IA</span>
    </h1>

    <p class="max-w-2xl mx-auto text-lg md:text-xl text-blue-100/80 mb-10 leading-relaxed">
      Maximizamos tu eficiencia y reducimos costos operativos mediante
      soluciones de IA personalizadas para el mercado local salvadoreño.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#contacto"
        class="w-full sm:w-auto bg-white text-[#001e3d] font-bold text-base px-8 py-3.5 rounded-xl hover:bg-blue-50 transition-colors shadow-lg focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#001e3d]"
      >
        Agenda una Consultoría
      </a>
      <a
        href="#servicios"
        class="w-full sm:w-auto border border-white/40 text-white font-semibold text-base px-8 py-3.5 rounded-xl hover:bg-white/10 transition-colors focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#001e3d]"
      >
        Ver Portafolio
      </a>
    </div>
  </div>
</section>

<style>
  /* Icons: float up, fade near the top */
  @keyframes floatUp {
    0%   { transform: translateY(0)       scale(1);    opacity: 0; }
    8%   { opacity: 0.85; }
    80%  { opacity: 0.5; }
    100% { transform: translateY(-90vh)   scale(0.6);  opacity: 0; }
  }

  .float-icon { animation: floatUp linear infinite; animation-fill-mode: backwards; }
  .fi-1 { animation-duration: 9s;  animation-delay: 0s;   }
  .fi-2 { animation-duration: 12s; animation-delay: 2.5s; }
  .fi-3 { animation-duration: 8s;  animation-delay: 4s;   }
  .fi-4 { animation-duration: 11s; animation-delay: 1s;   }
  .fi-5 { animation-duration: 10s; animation-delay: 3.2s; }
  .fi-6 { animation-duration: 13s; animation-delay: 0.8s; }
  .fi-7 { animation-duration: 9.5s; animation-delay: 5s;  }

  /* Cards: float up, fade out at midpoint (50%) */
  @keyframes floatUpCard {
    0%   { transform: translateY(0)       scale(1);    opacity: 0; }
    10%  { opacity: 1; }
    48%  { opacity: 1; }
    58%  { opacity: 0; }
    100% { transform: translateY(-62vh)   scale(0.92); opacity: 0; }
  }

  .float-card { animation: floatUpCard ease-in-out infinite; animation-fill-mode: backwards; }
  .fc-1 { animation-duration: 14s; animation-delay: 0s;   }
  .fc-2 { animation-duration: 18s; animation-delay: 4s;   }
  .fc-3 { animation-duration: 16s; animation-delay: 2s;   }
  .fc-4 { animation-duration: 20s; animation-delay: 7s;   }
</style>
