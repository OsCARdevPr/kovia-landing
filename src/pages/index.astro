---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problems from '../components/Problems.astro';
import Services from '../components/Services.astro';
import Mission from '../components/Mission.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="kovia | Automatización con IA para empresas en El Salvador"
  description="Automatizamos los procesos de tu empresa en El Salvador con IA: chatbots inteligentes, flujos automatizados, análisis de datos e integración ERP. Diagnóstico gratuito."
>
  <Nav />
  <main id="main-content">
    <Hero />
    <Problems />
    <Services />
    <Mission />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
