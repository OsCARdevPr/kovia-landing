---
import { SEO } from 'astro-seo';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = 'kovia | Automatización con IA para empresas en El Salvador',
  description = 'kovia automatiza los procesos de tu empresa en El Salvador con IA: chatbots, flujos inteligentes, análisis de datos e integración ERP. Agenda tu diagnóstico gratuito.',
  canonical = Astro.url.href,
  ogImage = '/og-kovia.png',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/imagenes/common/kovi.ico" />
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: {
          title: title,
          type: 'website',
          image: ogImage,
          url: canonical,
        },
        optional: {
          description: description,
          locale: 'es_SV',
          siteName: 'kovia',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: title,
        description: description,
        image: ogImage,
      }}
      extend={{
        meta: [
          { name: 'robots', content: 'index, follow' },
          { name: 'author', content: 'kovia' },
          { name: 'keywords', content: 'automatización IA El Salvador, chatbots empresas, inteligencia artificial El Salvador, automatización procesos, kovia, ERP integración, análisis datos' },
          { property: 'og:locale', content: 'es_SV' },
        ],
        link: [
          { rel: 'sitemap', href: '/sitemap-index.xml' },
        ],
      }}
    />

    <!-- JSON-LD: Organization structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "kovia",
      "url": "https://kovia.tech",
      "logo": "https://kovia.tech/imagenes/common/kovi.ico",
      "description": "Soluciones de IA y automatización para empresas en El Salvador",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "San Salvador",
        "addressCountry": "SV"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+503-7802-2630",
        "contactType": "customer service",
        "email": "koviatecnologies@gmail.com",
        "availableLanguage": "Spanish"
      }
    })} />
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Neo Tech';
    src: url('/fonts/Neo%20Tech%20Std%20Regular/Neo%20Tech%20Std%20Regular.otf') format('opentype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --bg: #090a0e;
    --surface: #12141a;
    --surface-soft: #171a22;
    --text-main: #f3f5f7;
    --text-muted: #a8adbb;
    --red-primary: #b12b24;
    --red-dark: #760504;
    --gold: #ffd700;
    --line-glow: rgba(177, 43, 36, 0.72);
  }

  html,
  body {
    margin: 0;
    padding: 0;
    background-color: var(--bg);
    color: var(--text-main);
  }

  body {
    font-family: 'JetBrains Mono', 'Segoe UI', Tahoma, sans-serif;
    background-image:
      radial-gradient(circle at 18% 0%, rgba(177, 43, 36, 0.24), transparent 42%),
      radial-gradient(circle at 82% 100%, rgba(118, 5, 4, 0.2), transparent 46%),
      linear-gradient(180deg, #090a0e 0%, #0d0e13 62%, #08090d 100%);
    min-height: 100vh;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.16;
    background-image:
      linear-gradient(rgba(255, 215, 0, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 215, 0, 0.04) 1px, transparent 1px);
    background-size: 90px 90px;
    z-index: -1;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: 'Neo Tech', 'JetBrains Mono', sans-serif;
    letter-spacing: 0.02em;
  }

  a {
    color: inherit;
  }

  .neon-divider {
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--red-primary) 28%, var(--gold) 50%, var(--red-primary) 72%, transparent 100%);
    box-shadow: 0 0 12px rgba(177, 43, 36, 0.9), 0 0 18px rgba(255, 215, 0, 0.35);
  }

  .neon-panel {
    background: linear-gradient(180deg, rgba(18, 20, 26, 0.94), rgba(10, 11, 16, 0.9));
    border: 1px solid rgba(177, 43, 36, 0.44);
    box-shadow: 0 0 0 1px rgba(255, 215, 0, 0.08) inset, 0 0 18px rgba(118, 5, 4, 0.4);
  }

  .neon-button {
    background: linear-gradient(135deg, var(--red-primary), var(--red-dark));
    border: 1px solid rgba(255, 215, 0, 0.42);
    box-shadow: 0 0 15px rgba(177, 43, 36, 0.55);
  }

  .neon-button:hover {
    box-shadow: 0 0 20px rgba(177, 43, 36, 0.78), 0 0 16px rgba(255, 215, 0, 0.28);
  }

  .robotic-logo-frame {
    position: relative;
    display: inline-flex;
    padding: 0.28rem;
    border-radius: 0.85rem;
    background: linear-gradient(150deg, #d4d7df 0%, #7d8492 37%, #e6e9ef 52%, #616978 100%);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.14) inset, 0 0 16px rgba(177, 43, 36, 0.45);
  }

  .robotic-logo-frame::after {
    content: '';
    position: absolute;
    inset: 4px;
    border-radius: 0.6rem;
    border: 1px solid rgba(9, 10, 14, 0.7);
    pointer-events: none;
  }
</style>
